# ──────────────────────────────────────────────
# Align-it 환경변수 템플릿
# 복사 후 .env.local 로 저장하고 값을 채우세요.
# ──────────────────────────────────────────────

# Spring Boot 백엔드 URL (로컬 개발)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# 프론트엔드 URL (OAuth 콜백 리다이렉트 기준)
NEXT_PUBLIC_APP_URL=http://localhost:3000
